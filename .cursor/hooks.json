{
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-start.js",
        "event": "sessionStart",
        "description": "Session start: optional context load (adapter-gated)."
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/session-end.js",
        "event": "sessionEnd",
        "description": "Session end: persist state and pattern eval."
      }
    ],
    "beforeShellExecution": [
      {
        "command": "npx block-no-verify@1.1.2",
        "event": "beforeShellExecution",
        "description": "Block --no-verify / hook-bypass on git commands."
      },
      {
        "command": "node .cursor/hooks/before-shell-execution.js",
        "event": "beforeShellExecution",
        "description": "Pre-shell: tmux guardrails, push review hints."
      }
    ],
    "afterShellExecution": [
      {
        "command": "node .cursor/hooks/after-shell-execution.js",
        "event": "afterShellExecution",
        "description": "Post-shell: PR URL log, build hints."
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/after-file-edit.js",
        "event": "afterFileEdit",
        "description": "Post-edit: format, TS check, console.log nudge."
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node .cursor/hooks/before-mcp-execution.js",
        "event": "beforeMCPExecution",
        "description": "Pre-MCP: audit log, untrusted-server warning."
      }
    ],
    "afterMCPExecution": [
      {
        "command": "node .cursor/hooks/after-mcp-execution.js",
        "event": "afterMCPExecution",
        "description": "Post-MCP: result logging."
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/before-read-file.js",
        "event": "beforeReadFile",
        "description": "Pre-read: warn on secrets paths (.env, keys, PEM)."
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/before-submit-prompt.js",
        "event": "beforeSubmitPrompt",
        "description": "Pre-submit: block obvious secrets in prompt text."
      }
    ],
    "subagentStart": [
      {
        "command": "node .cursor/hooks/subagent-start.js",
        "event": "subagentStart",
        "description": "Subagent start: observability log."
      }
    ],
    "subagentStop": [
      {
        "command": "node .cursor/hooks/subagent-stop.js",
        "event": "subagentStop",
        "description": "Subagent stop: completion log."
      }
    ],
    "beforeTabFileRead": [
      {
        "command": "node .cursor/hooks/before-tab-file-read.js",
        "event": "beforeTabFileRead",
        "description": "Pre-Tab read: block secrets paths."
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "node .cursor/hooks/after-tab-file-edit.js",
        "event": "afterTabFileEdit",
        "description": "Post-Tab edit: auto-format."
      }
    ],
    "preCompact": [
      {
        "command": "node .cursor/hooks/pre-compact.js",
        "event": "preCompact",
        "description": "Pre-compact: save hook state."
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop.js",
        "event": "stop",
        "description": "Stop: console.log audit on touched files."
      }
    ]
  }
}
